! ============================================================
! SD-WAN Lite Lab — R1 (Cisco Catalyst 8000 IOS-XE)
! PBR + IP SLA + Object Tracking
! Primary: GRE/IPSec Tunnel0 (172.16.0.2) via Track 1
! Backup:  GigabitEthernet1 direct (10.10.20.103)
! ============================================================

! --- Underlay interface (WAN) ---
interface GigabitEthernet1
 ip address 10.10.20.102 255.255.255.0
 no shutdown

! --- GRE/IPSec Tunnel0 (primary path — see gre-over-ipsec lab) ---
interface Tunnel0
 ip address 172.16.0.1 255.255.255.252
 tunnel source GigabitEthernet1
 tunnel destination 10.10.20.103
 tunnel protection ipsec profile GRE-IPSEC-PROFILE

! --- LAN interface (Area 1 source traffic) ---
interface GigabitEthernet2
 ip address 10.1.0.254 255.255.255.0
 ip policy route-map RM-PBR
 no shutdown

! --- IP SLA: ICMP probe toward Tunnel0 far-end ---
ip sla 1
 icmp-echo 172.16.0.2 source-interface Tunnel0
 frequency 10
ip sla schedule 1 life forever start-time now

! --- Object Track: monitor IP SLA 1 reachability ---
track 1 ip sla 1 reachability

! --- ACL: match Area1 -> Area2 traffic ---
ip access-list extended ACL-PBR
 permit ip 10.1.0.0 0.0.0.255 10.2.0.0 0.0.0.255

! --- Route-map: primary via Tunnel0 (tracked), fallback via Gi1 ---
route-map RM-PBR permit 10
 match ip address ACL-PBR
 set ip next-hop verify-availability 172.16.0.2 1 track 1
 set ip next-hop 10.10.20.103
